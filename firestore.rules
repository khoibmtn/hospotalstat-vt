rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }
    
    function isKeHoach() {
      return isAuthenticated() && getUserData().role == 'kehoach';
    }
    
    function isAdminOrKeHoach() {
      return isAdmin() || isKeHoach();
    }
    
    function hasDepartmentAccess(deptId) {
      let data = getUserData();
      return isAuthenticated() && (
        ('primaryDepartmentId' in data && data.primaryDepartmentId == deptId) ||
        ('additionalDepartments' in data && deptId in data.additionalDepartments)
      );
    }
    
    function canEditReport(deptId) {
      return isAdminOrKeHoach() || hasDepartmentAccess(deptId);
    }

    match /facilities/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /departments/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId; 
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }
    
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isKeHoach(); 
    }
    
    match /dailyReports/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && canEditReport(request.resource.data.departmentId);
      allow update: if isAuthenticated() && canEditReport(resource.data.departmentId) && canEditReport(request.resource.data.departmentId) && (isAdminOrKeHoach() || (!('status' in resource.data) && !('locked' in resource.data)) || resource.data.status != 'locked' && resource.data.locked != true);
      allow delete: if isAdmin(); 
    }
    
    match /auditLogs/{docId} {
      allow read: if isAdmin() || isKeHoach();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    match /{document=**} {
      allow read, write: if false; 
    }
  }
}