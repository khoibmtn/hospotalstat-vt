rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }
    
    function isKeHoach() {
      return isAuthenticated() && getUserData().role == 'kehoach';
    }
    
    function hasDepartmentAccess(deptId) {
      let deptIds = getUserData().get('departmentIds', []);
      return isAuthenticated() && (deptId in deptIds);
    }
    
    function canEditReport(deptId) {
      return isAdmin() || isKeHoach() || hasDepartmentAccess(deptId);
    }

    match /facilities/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /departments/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId; 
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }
    
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isKeHoach(); 
    }
    
    match /dailyReports/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && canEditReport(request.resource.data.departmentId);
      // For updates, ensure the user has access to BOTH the current department and the new department (even though department shouldn't change)
      // Note: when unlocking/locking, KeHoach updates reports for various departments. Their canEditReport will return true because isKeHoach() is true.
      allow update: if isAuthenticated() && canEditReport(resource.data.departmentId) && canEditReport(request.resource.data.departmentId);
      allow delete: if isAdmin(); 
    }
    
    match /auditLogs/{docId} {
      allow read: if isAdmin() || isKeHoach();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    match /{document=**} {
      allow read, write: if false; 
    }
  }
}